{
  "name": "docmayscience",
  "version": "1.0.0",
  "private": true,
  "description": "Personal site for Dr. Joseph May (@docmayscience) — docmayscience.com",
  "scripts": {
    "dev": "live-server --port=5500",
    "dev:quiet": "live-server --port=5500 --no-browser",
    "lint": "html-validate *.html",
    "links": "linkinator . --recurse --skip \"^https?://(?!localhost)\"",
    "check": "npm run lint && npm run links"
  },
  "devDependencies": {
    "html-validate": "^11.5.5",
    "linkinator": "^7.6.1",
    "live-server": "^1.2.2"
  }
}
